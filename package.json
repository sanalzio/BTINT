{
  "name": "@sanalzio/btint",
  "version": "0.2.0",
  "description": " 🎨 A terminal tool that modifies image colors according to your selected palette, optimizing your visual experience. ",
  "main": "bin/btint.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "bun build --packages=bundle --target=bun --outfile=./dist/btint.js --minify ./bin/btint.js"
